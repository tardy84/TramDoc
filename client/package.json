    "ios:check-native": "node scripts/check-ios-native.mjs",
    "ios:doctor": "cap doctor ios",
    "ios:preflight": "npm run ios:validate-env && npm run ios:smoke-api && npm run ios:check-native",
    "ios:set-version": "node scripts/set-ios-version.mjs",
    "ios:smoke-api": "node scripts/smoke-ios-api.mjs",
    "ios:sync": "cap sync ios",
    "ios:xcode-check": "node scripts/check-xcode.mjs",
    "ios:validate-env": "node scripts/validate-ios-env.mjs",
    "ios:open": "cap open ios",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/cli": "8.3.0",
    "@capacitor/core": "8.3.0",
    "@capacitor/ios": "8.3.0",
    "axios": "^1.13.5",
    "chart.js": "^4.5.1",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0"
  }
