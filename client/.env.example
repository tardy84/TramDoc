# Browser dev can omit this and use the Vite proxy at /api, /covers, /audio.
# iOS/TestFlight builds must set this to the public HTTPS server origin:
# VITE_API_URL=https://api.your-domain.com
#
# Optional local direct API override:
# VITE_API_URL=http://localhost:3005

# Do not put TTS provider API keys in client Vite env files for iOS/release builds.
# Provider keys such as VBEE_TOKEN belong in /server/.env.
