# Browser API calls use /api and Vite proxies to http://localhost:3005.
# Optional override for direct API calls:
# VITE_API_URL=http://localhost:3005

# Optional client-side TTS keys can also be entered in the app settings.
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=southeastasia
VITE_GOOGLE_CLOUD_API_KEY=
VITE_MINIMAX_API_KEY=
VITE_GEMINI_API_KEY=
