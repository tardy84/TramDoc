AZURE_SPEECH_REGION=southeastasia
GOOGLE_TTS_API_KEY=
GOOGLE_CLOUD_API_KEY=
MINIMAX_API_KEY=
GEMINI_API_KEY=
VBEE_APP_ID=
VBEE_TOKEN=
VBEE_CALLBACK_URL=

# Google Auth (currently unused unless social login is wired)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
